NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
ADMIN_EMAIL=
NEXT_PUBLIC_CALENDLY_DISCOVERY_URL=
NEXT_PUBLIC_CALENDLY_STRATEGY_URL=
NEXT_PUBLIC_BASE_URL=http://localhost:3000
ANTHROPIC_API_KEY=your_key_here
MOLLIE_API_KEY=test_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_SHOP_URL=http://localhost:3000

# Cycle Companion (markdekock.com/Cycle)
# Shared password for the open-URL login. Anyone with this password can log in.
CYCLE_PASSWORD=mycycle2026
# Email of the Supabase Auth user that the password logs into. Must already exist in auth.users.
CYCLE_DEFAULT_EMAIL=her@example.com
# Comma-separated allowlist still enforced after login (hold-session check).
CYCLE_ALLOWED_EMAILS=her@example.com,mark@brandpwrdmedia.com
# Optional — sender for the daily reminder email. Defaults to results@brandpwrdmedia.com.
CYCLE_REMINDER_FROM="Cycle <results@brandpwrdmedia.com>"
# Required for Vercel Cron — the reminder route checks Authorization: Bearer ${CRON_SECRET}.
CRON_SECRET=
